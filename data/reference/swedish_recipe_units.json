  "guard_rules": [
    {
      "name": "swedish_spoon_guard",
      "description": "Swedish tsk and msk must retain their spoon identity throughout preprocessing and normalization.",
      "fail_on": [
        "tsk -> tbsp",
        "msk -> tsp"
      ]
    },
    {
      "name": "metric_notation_guard",
      "description": "Do not drop explicit dl, ml, cl, g, hg, kg values into preparation text when they can remain structured.",
      "fail_on": [
        "1 dl -> freeform note only",
        "a pinch -> freeform note only when count-like quantity is supported"
      ]
    },
    {
      "name": "package_unit_guard",
      "description": "Package nouns are not equivalent to grams or milliliters without explicit size data.",
      "fail_on": [
        "burk -> guessed grams",
        "paket -> guessed grams",
        "påse -> guessed grams"
      ]
    }
