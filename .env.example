# App
NODE_ENV=development
PORT=3000
API_PORT=8000
# Nginx reverse proxy port (used with make up-proxy). Default: 8080.
# Change to 80 for standard HTTP port (may require root/sudo on some systems).
NGINX_PORT=8080

# Database
DATABASE_URL=sqlite:./data/db/galley.sqlite

# Media
MEDIA_DIR=./data/media
IMPORTS_DIR=./data/imports
EXPORTS_DIR=./data/exports
BACKUPS_DIR=./data/backups

# LM Studio
LM_STUDIO_ENABLED=false
LM_STUDIO_BASE_URL=http://localhost:1234/v1
# When running under Docker compose, use host.docker.internal instead of localhost:
# LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
# Example for a LAN-hosted LM Studio server:
# LM_STUDIO_BASE_URL=http://192.168.1.91:1234/v1
LM_STUDIO_MODEL=Qwen/Qwen2.5-7B-Instruct

# Search / embeddings
EMBEDDINGS_DIR=./data/embeddings
